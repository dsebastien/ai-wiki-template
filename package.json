{
  "name": "ai-wiki-template",
  "version": "0.1.3",
  "private": true,
  "description": "Static-site template for OSK LLM Wikis. Tailwind v4, themable, search + knowledge graph, deploys to GitHub Pages or Cloudflare Pages.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "sync": "bun scripts/sync.ts",
    "build": "bun scripts/build.ts",
    "serve": "bun scripts/serve.ts",
    "dev": "bun run sync && bun run build && bun run serve",
    "clean": "rm -rf public",
    "release": "bun scripts/release.ts"
  },
  "engines": {
    "bun": ">=1.1"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lunr": "^2.3.9",
    "marked": "^14.1.4",
    "marked-gfm-heading-id": "^4.1.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "tailwindcss": "^4.1.13",
    "@types/lunr": "^2.3.7",
    "@types/bun": "latest"
  }
}
